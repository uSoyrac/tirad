# ============================================================
# ALPHA İSTİHBARAT SİSTEMİ — API ANAHTARLARI
# Bu dosyayı .env olarak kopyala ve doldur
# ============================================================

# Anthropic (Claude API) — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Binance (sadece okuma yetkisi yeterli) — https://binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_here

# YouTube Data API v3 — https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gmail SMTP (App Password — Google Hesabı > Güvenlik > 2FA açık > App Passwords)
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENT=your_gmail@gmail.com

# Opsiyonel: CoinGecko Pro (ücretsiz tier için boş bırak)
COINGECKO_API_KEY=

# Opsiyonel: CryptoQuant (ücretsiz tier)
CRYPTOQUANT_API_KEY=

# ─── TRADING BOT AYARLARI ────────────────────────────────────
# Binance API — İşlem yetkisi gerekli (Futures Trade izni aç)
# ÖNEMLİ: IP whitelist ekle, sadece kendi IP'ni izin ver!

BOT_DRY_RUN=true          # true=kuru mod (emir göndermez), false=canli
BOT_MIN_SCORE=6.0         # Sinyal için minimum skor (6.0 önerilen)
BOT_DB=data/database/bot_positions.db  # Pozisyon veritabanı
